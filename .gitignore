# ============================================================
# .gitignore - 企业全生命周期税务问题知识库
# ============================================================

# ------------------- 数据库 -------------------
# SQLite 数据库文件（本地开发用，不提交到仓库）
*.db
*.sqlite
*.sqlite3

# ------------------- Node.js -------------------
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# ------------------- Python -------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/

# ------------------- 前端构建 -------------------
# React/Vue 等前端框架
frontend/dist/
frontend/build/
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local

# Next.js
frontend/.next/
frontend/out/

# ------------------- 环境变量 -------------------
# .env 文件（包含敏感信息）
.env
.env.local
.env.*.local

# ------------------- IDE -------------------
# JetBrains
.idea/
*.iml
*.iws
*.ipr

# VS Code
.vscode/
*.swp
*.swo
*~

# ------------------- 系统文件 -------------------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ------------------- 日志 -------------------
*.log
logs/

# ------------------- 临时文件 -------------------
*.tmp
*.temp
*.bak
*.cache

# ------------------- 测试 -------------------
coverage/
.nyc_output/

# ------------------- 压缩包 -------------------
*.zip
*.tar
*.tar.gz
*.rar

# ------------------- 后端 -------------------
backend/__pycache__/
backend/*.pyc
backend/.venv/
backend/venv/
backend/env/

# ------------------- 数据导入导出 -------------------
data/exports/*.json
data/exports/*.csv
data/drafts/*.tmp
