# ============================================================
# .env.example - 环境变量示例
# ============================================================
# 复制此文件为 .env，并填入真实值（Windows用set，Linux/Mac用export）

# ------------------- 安全配置（必须设置） -------------------
# ⚠️ 重要：ADMIN_PASSWORD 和 SECRET_KEY 必须设置，否则服务无法启动
# 生产环境必须使用强密码和随机密钥，不得使用默认值、空值或弱密码
ADMIN_PASSWORD=<请设置一个强密码>
# 随机密钥生成命令：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Flask调试模式（生产必须为 0）
FLASK_DEBUG=0

# 服务器配置
HOST=0.0.0.0
PORT=5000

# 数据库路径：容器或外部挂载部署时建议显式指定
DATABASE_PATH=database/db/tax_knowledge.db

# 站点配置
SITE_NAME=企业税务知识库
SITE_URL=http://127.0.0.1:5000
SITE_DESCRIPTION=面向企业全生命周期税务问题的结构化知识库

# ------------------- 技术说明 -------------------
# 当前技术栈：Flask + Jinja2 + SQLite + Gunicorn
# DATABASE_PATH 未设置时，默认使用项目内的 database/db/tax_knowledge.db
