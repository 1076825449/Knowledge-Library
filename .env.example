# ============================================================
# .env.example - 环境变量示例
# ============================================================
# 复制此文件为 .env，并填入真实值（Windows用set，Linux/Mac用export）

# ------------------- 安全配置（必须覆盖） -------------------
# 管理员密码（默认：tax2026，仅供本地开发使用）
ADMIN_PASSWORD=tax2026

# Flask会话密钥（默认：tax-knowledge-library-secret-2026，生产必须更换）
SECRET_KEY=tax-knowledge-library-secret-2026

# ------------------- 技术说明 -------------------
# 当前技术栈：Flask + Jinja2 + SQLite
# 数据库路径在 backend/config.py 中硬编码为 database/db/tax_knowledge.db
# 如需更换数据库，请修改 backend/config.py
