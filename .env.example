# ============================================================
# .env.example - 环境变量示例
# ============================================================
# 复制此文件为 .env，并填入真实值（Windows用set，Linux/Mac用export）

# ------------------- 安全配置（必须覆盖） -------------------
# 管理员密码（默认：tax2026，仅供本地开发使用）
ADMIN_PASSWORD=tax2026

# Flask会话密钥（默认：tax-knowledge-library-secret-2026，生产必须更换）
SECRET_KEY=tax-knowledge-library-secret-2026

# 生产运行参数
HOST=0.0.0.0
PORT=5000
FLASK_DEBUG=0

# 数据库路径：容器或外部挂载部署时建议显式指定
DATABASE_PATH=database/db/tax_knowledge.db

# ------------------- 技术说明 -------------------
# 当前技术栈：Flask + Jinja2 + SQLite + Gunicorn
# DATABASE_PATH 未设置时，默认使用项目内的 database/db/tax_knowledge.db
