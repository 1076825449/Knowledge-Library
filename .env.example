# ============================================================
# .env.example - 环境变量示例
# ============================================================

# ------------------- 数据库配置 -------------------
# SQLite（当前阶段默认）
DB_TYPE=sqlite
DB_PATH=./database/db/tax_knowledge.db

# MySQL（后续迁移可选）
# DB_TYPE=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=tax_knowledge
# DB_USER=root
# DB_PASSWORD=

# PostgreSQL（后续迁移可选）
# DB_TYPE=postgresql
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=tax_knowledge
# DB_USER=postgres
# DB_PASSWORD=

# ------------------- 应用配置 -------------------
APP_NAME=税务问题知识库
APP_ENV=development
APP_DEBUG=true
APP_PORT=3000

# ------------------- 前端配置 -------------------
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_APP_NAME=税务问题知识库

# ------------------- 搜索配置 -------------------
# 全文检索引擎（后续扩展）
# SEARCH_ENABLED=false
# SEARCH_ENGINE=sqlite_fts
